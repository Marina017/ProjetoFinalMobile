<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.projetofinal.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.projetofinal.HomeFragment"
        android:label="Remédios"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_detalhes"
            app:destination="@id/detalhesFragment" />
    </fragment>

    <fragment
        android:id="@+id/cadastroFragment"
        android:name="com.example.projetofinal.CadastroFragment"
        android:label="Cadastrar"
        tools:layout="@layout/fragment_cadastro" />

    <fragment
        android:id="@+id/detalhesFragment"
        android:name="com.example.projetofinal.DetalhesFragment"
        android:label="Detalhes"
        tools:layout="@layout/fragment_detalhes" />

    <fragment
        android:id="@+id/perfilFragment"
        android:name="com.example.projetofinal.PerfilFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_perfil_">

        <action
            android:id="@+id/action_perfil_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>